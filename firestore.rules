rules_version = '2';

// ══════════════════════════════════════════════════════════════════════════════
// Gong Cha Admin Panel — Firestore Security Rules
// Policy:
//   • Default DENY all.
//   • All writes to sensitive collections go through Admin SDK (API routes).
//   • Admin panel collections require isAdminUser().
//   • Public-facing collections (stores, menus/products) allow public READ.
// ══════════════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────────────────

    function isAdminUser() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admin_users/$(request.auth.uid));
    }

    function isSuperAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/admin_users/$(request.auth.uid)).data.role == "SUPER_ADMIN";
    }


    // ── /admin_users ──────────────────────────────────────────────────────────
    // Any admin can list ALL admin_users (Staff page & Dashboard).
    // Writes: Admin SDK only (/api/setup-user).
    match /admin_users/{uid} {
      allow read:  if isAdminUser();
      allow write: if false;
    }


    // ── /users (Customer Members) ─────────────────────────────────────────────
    // Admins can list all members (Dashboard & Members page).
    // Members can read and lightly update their own profile.
    // Writes: Admin SDK only (/api/members).
    match /users/{userId} {
      allow read:   if isAdminUser() || (request.auth != null && request.auth.uid == userId);
      allow update: if request.auth != null &&
                       request.auth.uid == userId &&
                       request.resource.data.diff(resource.data)
                         .affectedKeys().hasOnly(['phoneNumber', 'photoURL', 'fcmToken']);
      allow create: if false;
      allow delete: if false;
    }


    // ── /menus ────────────────────────────────────────────────────────────────
    // Customer App reads menus without login.
    // Writes: Admin SDK only.
    match /menus/{id} {
      allow read:  if true;
      allow write: if false;
    }


    // ── /products (alias used by admin panel MenusClient) ─────────────────────
    match /products/{id} {
      allow read:  if true;
      allow write: if false;
    }


    // ── /stores ───────────────────────────────────────────────────────────────
    // Customer App reads store list without login.
    // Writes: Admin SDK only.
    match /stores/{storeId} {
      allow read:  if true;
      allow write: if false;

      // Subcollection: stores/{storeId}/transactions
      match /transactions/{txId} {
        allow read:  if isAdminUser();
        allow write: if false;
      }
    }


    // ── /transactions (top-level) ─────────────────────────────────────────────
    // Writes: Admin SDK only (/api/transactions).
    match /transactions/{id} {
      allow read:  if isAdminUser();
      allow write: if false;
    }


    // ── /rewards ──────────────────────────────────────────────────────────────
    // Writes: Admin SDK only (/api/rewards).
    match /rewards/{id} {
      allow read:  if isAdminUser();
      allow write: if false;
    }


    // ── /rewards_catalog (legacy alias) ───────────────────────────────────────
    match /rewards_catalog/{id} {
      allow read:  if isAdminUser();
      allow write: if false;
    }


    // ── /notifications ────────────────────────────────────────────────────────
    // Admin can list all notifications; members can read their own.
    // Members can mark their own notifications as read.
    // Writes: Admin SDK only (/api/notifications).
    match /notifications/{notifId} {
      allow read:   if isAdminUser() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow update: if request.auth != null &&
                       resource.data.userId == request.auth.uid &&
                       request.resource.data.diff(resource.data)
                         .affectedKeys().hasOnly(['isRead']);
      allow create: if false;
      allow delete: if false;
    }


    // ── /notifications_log ────────────────────────────────────────────────────
    // Internal audit log. Admin SDK only — no client access.
    match /notifications_log/{logId} {
      allow read, write: if false;
    }


    // ── /settings ─────────────────────────────────────────────────────────────
    // Writes: Admin SDK only (/api/settings).
    match /settings/{settingId} {
      allow read:  if isAdminUser();
      allow write: if false;
    }


    // ── /accounts ─────────────────────────────────────────────────────────────
    // AccountsClient queries this for the /accounts admin page.
    // Writes: Admin SDK only (/api/accounts).
    match /accounts/{accountId} {
      allow read:  if isAdminUser();
      allow write: if false;
    }


    // ── /staff (legacy — superseded by admin_users) ───────────────────────────
    match /staff/{staffId} {
      allow read, write: if false;
    }


    // ── DEFAULT DENY ──────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

  }
}
