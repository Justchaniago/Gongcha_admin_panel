rules_version = '2';

// ══════════════════════════════════════════════════════════════════════════════
// Fase 7 — Architecture Hardening: Firestore Security Rules
// Policy:
//   • Default DENY all.
//   • Admin-panel collections require Firebase Authentication.
//   • All mutations to sensitive collections go through Admin SDK (API routes)
//     and are therefore blocked at the client-SDK level (allow write: if false).
//   • Public-facing collections (products/stores) allow unauthenticated READ
//     so the Customer App can display menus and store info without login.
// ══════════════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────────────────

    // True when the request carries a valid Firebase Auth token.
    function isSignedIn() {
      return request.auth != null;
    }

    // True when the caller exists in the admin_users collection.
    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admin_users/$(request.auth.uid));
    }


    // ── /admin_users ──────────────────────────────────────────────────────────
    // Admin profile directory.
    // Any admin can list ALL admin_users (needed for Staff page & Dashboard).
    // A signed-in user can always read their own profile.
    // All writes go through the Admin SDK (API routes).
    match /admin_users/{userId} {
      allow read:   if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow create: if false; // Admin SDK only (/api/setup-user)
      allow update: if false; // Admin SDK only
      allow delete: if false; // Admin SDK only
    }


    // ── /users (Customer Members) ─────────────────────────────────────────────
    // Admins can list/read all member profiles (needed for Dashboard & Members page).
    // Members can read and lightly update their own profile.
    // Account creation / deletion goes through Admin SDK.
    match /users/{userId} {
      allow read:   if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow update: if isSignedIn() &&
                       request.auth.uid == userId &&
                       request.resource.data.diff(resource.data)
                         .affectedKeys().hasOnly(['phoneNumber', 'photoURL', 'fcmToken']);
      allow create: if false; // Admin SDK only (/api/members)
      allow delete: if false; // Admin SDK only
    }


    // ── /products (Menus) ─────────────────────────────────────────────────────
    // Customer App needs unauthenticated read to display the menu.
    // All writes are performed exclusively via Admin SDK (menuActions.ts).
    match /products/{productId} {
      allow read:  if true;   // Public — Customer App can fetch menu without login
      allow write: if false;  // Admin SDK only (menuActions.ts / Server Actions)
    }


    // ── /stores ───────────────────────────────────────────────────────────────
    // Customer App needs unauthenticated read to list nearby stores.
    // All writes are performed via Admin SDK (storeActions.ts / API routes).
    match /stores/{storeId} {
      allow read:  if true;   // Public — Customer App can fetch store list without login
      allow write: if false;  // Admin SDK only

      // Sub-collection: store-level transactions
      match /transactions/{txId} {
        allow read:  if isAdmin(); // Admin panel can read via collectionGroup/direct
        allow write: if false;    // Admin SDK only
      }
    }


    // ── /transactions (Top-level) ─────────────────────────────────────────────
    // All transaction mutations go through Admin SDK API routes.
    // Only verified admins may list/read transactions.
    match /transactions/{txId} {
      allow read:  if isAdmin(); // Admin-only — prevents unauthorized listing
      allow write: if false;     // Admin SDK only (/api/transactions)
    }


    // ── /rewards ──────────────────────────────────────────────────────────────
    // Reward catalog. Only admins may list rewards via the admin panel.
    // All writes go through Admin SDK (/api/rewards).
    match /rewards/{rewardId} {
      allow read:  if isAdmin(); // Admin-only (add "|| true" here if public read needed later)
      allow write: if false;     // Admin SDK only
    }

    // ── /rewards_catalog (Legacy alias — kept for backwards compat) ───────────
    match /rewards_catalog/{rewardId} {
      allow read:  if isSignedIn();
      allow write: if false; // Admin SDK only
    }


    // ── /notifications ────────────────────────────────────────────────────────
    // Each notification document carries a userId field.
    // Members can read/mark-as-read their own notifications only.
    // Creation and deletion go through Admin SDK.
    match /notifications/{notifId} {
      allow read:   if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() &&
                       resource.data.userId == request.auth.uid &&
                       request.resource.data.diff(resource.data)
                         .affectedKeys().hasOnly(['isRead']);
      allow create: if false; // Admin SDK only (/api/notifications)
      allow delete: if false;
    }


    // ── /notifications_log ────────────────────────────────────────────────────
    // Internal audit log written by Admin SDK. No client access.
    match /notifications_log/{logId} {
      allow read, write: if false; // Admin SDK only
    }


    // ── /settings ─────────────────────────────────────────────────────────────
    // Global app config. Read by authenticated admin panel users.
    // Writes exclusively via Admin SDK (/api/settings).
    match /settings/{settingId} {
      allow read:  if isSignedIn();
      allow write: if false; // Admin SDK only
    }


    // ── /accounts ─────────────────────────────────────────────────────────────
    // AccountsClient queries this collection for the /accounts admin page.
    match /accounts/{accountId} {
      allow read:  if isAdmin(); // Admin panel read
      allow write: if false;    // Admin SDK only (/api/accounts)
    }

    // ── /staff (Legacy — superseded by admin_users) ───────────────────────────
    match /staff/{staffId} {
      allow read, write: if false; // Migrated to admin_users; no direct access
    }


    // ── DEFAULT DENY ──────────────────────────────────────────────────────────
    // Any collection not explicitly matched above is fully closed.
    match /{document=**} {
      allow read, write: if false;
    }

  }
}
