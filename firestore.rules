rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function normalizeRole(value) {
      return value == null
        ? ""
        : value == "SUPER_ADMIN" || value == "ADMIN" || value == "MASTER" || value == "admin" || value == "master"
          ? "SUPER_ADMIN"
          : value == "STAFF" || value == "MANAGER" || value == "manager"
            ? "STAFF"
            : value;
    }

    function isActiveFlag(data) {
      return !("isActive" in data) || data.isActive == true;
    }

    // Legacy helper (kept for backward compatibility with old /staff collection)
    function staffHasRole(roles) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/staff/$(request.auth.uid)) &&
        isActiveFlag(get(/databases/$(database)/documents/staff/$(request.auth.uid)).data) &&
        normalizeRole(get(/databases/$(database)/documents/staff/$(request.auth.uid)).data.role) in roles;
    }

    // Current admin panel role source: /admin_users
    function adminUserHasRole(roles) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admin_users/$(request.auth.uid)) &&
        isActiveFlag(get(/databases/$(database)/documents/admin_users/$(request.auth.uid)).data) &&
        normalizeRole(get(/databases/$(database)/documents/admin_users/$(request.auth.uid)).data.role) in roles;
    }

    // Legacy helper for old schema in /users
    function userIsAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        normalizeRole(get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role) == 'SUPER_ADMIN';
    }

    function isPrivilegedAdmin() {
      return adminUserHasRole(['SUPER_ADMIN']) || userIsAdmin() || staffHasRole(['SUPER_ADMIN', 'store_manager']);
    }

    function isActiveAdminPanelUser() {
      return adminUserHasRole(['SUPER_ADMIN', 'STAFF']) || staffHasRole(['SUPER_ADMIN', 'STAFF', 'cashier', 'store_manager']);
    }

    // ── /admin_users ───────────────────────────────────────────────────────
    match /admin_users/{uid} {
      // Each admin/staff can read own profile; super admin can read all.
      allow read: if isSignedIn() && (request.auth.uid == uid || isPrivilegedAdmin());
      // Mutations should go through Admin SDK routes/actions.
      allow create, update, delete: if false;
    }

    // ── /accounts ──────────────────────────────────────────────────────────
    // Only admin staff or admin users may read/write accounts.
    // Actual mutations go through API routes (Admin SDK bypasses these rules),
    // but we restrict direct client-SDK writes as a safety net.
    match /accounts/{accountId} {
      allow read:   if staffHasRole(['SUPER_ADMIN', 'store_manager']) || userIsAdmin();
      allow create: if false; // Must use /api/accounts (Admin SDK)
      allow update: if false; // Must use /api/accounts/[id] (Admin SDK)
      allow delete: if false; // Must use /api/accounts/[id] (Admin SDK)
    }

    // ── /users ─────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Any authenticated user can read their own document
      allow read:   if isSignedIn() && (request.auth.uid == userId || isActiveAdminPanelUser() || userIsAdmin());
      // Users can update their own limited fields
      allow update: if isSignedIn() && request.auth.uid == userId &&
                       request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['phoneNumber', 'photoURL']);
      allow create: if false; // Must use /api/members (Admin SDK)
      allow delete: if false; // Must use /api/members/[uid] (Admin SDK)
    }

    // ── /staff ─────────────────────────────────────────────────────────────
    match /staff/{staffId} {
      // Staff can read their own doc; admins can read all
      allow read:   if isSignedIn() && (request.auth.uid == staffId || staffHasRole(['SUPER_ADMIN', 'store_manager']) || userIsAdmin());
      allow create: if false; // Must use /api/staff (Admin SDK)
      allow update: if false; // Must use /api/staff/[uid] (Admin SDK)
      allow delete: if false; // Must use /api/staff/[uid] (Admin SDK)
    }

    // ── /stores ────────────────────────────────────────────────────────────
    match /stores/{storeId} {
      // Anyone signed in can read store list (needed for POS UI)
      allow read:   if isSignedIn();
      allow write:  if isPrivilegedAdmin();
    }

    // ── /products ──────────────────────────────────────────────────────────
    // Admin panel menu management collection.
    match /products/{productId} {
      allow read:  if isActiveAdminPanelUser();
      allow write: if isPrivilegedAdmin();
    }

    // 🔥 God Schema: Top-Level Transactions
    match /transactions/{txId} {
      // Izinkan baca JIKA user adalah Admin/Staff AKTIF, ATAU user adalah MEMBER pemilik transaksi tersebut
      allow read: if isActiveAdminPanelUser() || (request.auth != null && resource.data.uid == request.auth.uid);

      // Klien (Member App/Admin Panel) tidak boleh menulis langsung ke sini.
      // Semua penulisan di-handle secara Atomic melalui server/backend service.
      allow create, update, delete: if false;
    }

    // ── /daily_stats ────────────────────────────────────────────────────────
    // Dashboard aggregate docs.
    match /daily_stats/{statId} {
      allow read: if isActiveAdminPanelUser();
      allow create, update, delete: if false;
    }

    // ── /stores/{storeId}/transactions ─────────────────────────────────────
    match /stores/{storeId}/transactions/{txId} {
      // Cashiers can create; managers/admins can read and update status
      allow read:   if isSignedIn() && (staffHasRole(['cashier', 'store_manager', 'SUPER_ADMIN', 'STAFF']) || userIsAdmin());
      allow create: if staffHasRole(['cashier', 'store_manager', 'SUPER_ADMIN', 'STAFF']);
      allow update: if staffHasRole(['store_manager', 'SUPER_ADMIN', 'STAFF']) || userIsAdmin();
      allow delete: if false;
    }

    // ── /rewards_catalog ───────────────────────────────────────────────────
    match /rewards_catalog/{rewardId} {
      allow read:   if isActiveAdminPanelUser() || isSignedIn();
      allow write:  if isPrivilegedAdmin();
    }

    // ── /rewards ───────────────────────────────────────────────────────────
    // Current admin app reads this collection directly via client SDK.
    // Mutations should still go through Admin SDK routes.
    match /rewards/{rewardId} {
      allow read:   if isActiveAdminPanelUser() || isSignedIn();
      allow write:  if isPrivilegedAdmin();
    }

    // ── /settings ──────────────────────────────────────────────────────────
    // Global app settings (e.g. settings/global).
    // Read: any authenticated staff or admin user.
    // Write: only admin staff or admin users — but mutations go through
    //        /api/settings (Admin SDK), so direct client writes are blocked.
    match /settings/{settingId} {
      allow read:   if isActiveAdminPanelUser() || userIsAdmin();
      allow create: if false; // Must use /api/settings (Admin SDK)
      allow update: if false; // Must use /api/settings (Admin SDK)
      allow delete: if false;
    }

    // ── /notifications ─────────────────────────────────────────────────────
    // Flat collection written by Admin SDK; customer app reads its own docs.
    // Admin panel reads via Admin SDK (bypasses rules).
    match /notifications/{notifId} {
      // Customer users can only read their own notifications
      allow read:   if isSignedIn() && resource.data.userId == request.auth.uid;
      // Users can mark their own notification as read (update isRead only)
      allow update: if isSignedIn() &&
                       resource.data.userId == request.auth.uid &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      allow create: if false; // Must use Admin SDK (API route)
      allow delete: if false;
    }

    // ── /notifications_log ─────────────────────────────────────────────────
    // Admin-only log; all access via Admin SDK (API routes).
    match /notifications_log/{logId} {
      allow read, write: if false; // Admin SDK only
    }

    // ── Deny everything else ───────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
